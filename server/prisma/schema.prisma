generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  password            String?
  nickname            String?
  provider            String    @default("email")
  emailVerified       Boolean   @default(false)
  onboardingCompleted Boolean   @default(false)
  cashBalance         Decimal   @default(0) @db.Decimal(15, 2)
  verificationToken   String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  accounts            Account[]
  cards               Card[]
  transactions        Transaction[]
  categories          Category[]
  budgets             Budget[]
}

model Account {
  id           Int           @id @default(autoincrement())
  userId       Int
  user         User          @relation(fields: [userId], references: [id])
  bankName     String
  alias        String?
  balance      Decimal       @default(0) @db.Decimal(15, 2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  linkedCards  Card[]        @relation("CardLinkedAccount")
}

model Card {
  id              Int           @id @default(autoincrement())
  userId          Int
  user            User          @relation(fields: [userId], references: [id])
  cardCompany     String
  alias           String?
  cardType        String        @default("credit")
  paymentDay      Int?
  linkedAccountId Int?
  linkedAccount   Account?      @relation("CardLinkedAccount", fields: [linkedAccountId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  transactions    Transaction[]
}

model Category {
  id           Int           @id @default(autoincrement())
  userId       Int?
  user         User?         @relation(fields: [userId], references: [id])
  type         String
  name         String
  icon         String?
  sortOrder    Int           @default(0)
  isDefault    Boolean       @default(false)
  transactions Transaction[]
  budgets      Budget[]
}

model Transaction {
  id            Int       @id @default(autoincrement())
  userId        Int
  user          User      @relation(fields: [userId], references: [id])
  type          String
  amount        Decimal   @db.Decimal(15, 2)
  categoryId    Int?
  category      Category? @relation(fields: [categoryId], references: [id])
  accountId     Int?
  account       Account?  @relation(fields: [accountId], references: [id])
  cardId        Int?
  card          Card?     @relation(fields: [cardId], references: [id])
  paymentMethod String    @default("cash")
  memo          String?
  date          DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Budget {
  id         Int       @id @default(autoincrement())
  userId     Int
  user       User      @relation(fields: [userId], references: [id])
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])
  amount     Decimal   @db.Decimal(15, 2)
  month      String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}
