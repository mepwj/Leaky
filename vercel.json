{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null,
  "rewrites": [
    {
      "source": "/apk/:path*",
      "destination": "http://mepwj.iptime.org:3000/downloads/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "http://mepwj.iptime.org:3000/:path*"
    }
  ]
}
